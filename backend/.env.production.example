# Production Environment Variables
# Copy this file to .env for production deployment

# Environment
NODE_ENV=production

# Server
PORT=5000

# MongoDB Connection
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trafficjam?retryWrites=true&w=majority

# Optional: Fallback MongoDB connection (if SRV lookup fails)
# MONGO_URI_FALLBACK=mongodb://host1:27017,host2:27017/trafficjam?replicaSet=...&ssl=true

# JWT Secret (CRITICAL - Generate using: node generateSecrets.js)
# MUST be at least 64 characters long
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET_FROM_generateSecrets.js

# Frontend URL (your production domain)
# Example: https://yourdomain.com or https://trafficjam.vercel.app
FRONTEND_URL=https://yourdomain.com

# Optional: Session Secret (for future use)
SESSION_SECRET=REPLACE_WITH_GENERATED_SECRET_FROM_generateSecrets.js

# Optional: Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# Optional: Logging Level
LOG_LEVEL=info

# Optional: Error Monitoring (Sentry)
# SENTRY_DSN=your_sentry_dsn_here

# Optional: Email Service (for future email verification)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=noreply@yourdomain.com
