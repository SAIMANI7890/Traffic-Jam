# Backend env
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/trafficjam
# Optional: if your primary MONGO_URI uses mongodb+srv and SRV DNS lookup fails,
# set a standard (non-SRV) connection string here (from MongoDB Atlas "Standard connection string").
# MONGO_URI_FALLBACK=mongodb://user:pass@host1:27017,host2:27017,host3:27017/db?replicaSet=...&ssl=true&authSource=admin
JWT_SECRET=change_me_to_a_long_random_string
